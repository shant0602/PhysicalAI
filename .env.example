# Copy this file to .env and fill in your values.
# docker-compose automatically loads .env from the project root.
# Never commit .env to git — it is already in .gitignore.

# Required for experiment tracking
WANDB_API_KEY=your_wandb_api_key_here

# Required for training — set to your W&B username or team name
WANDB_ENTITY=your_wandb_username_or_team

# Optional — only needed for gated HuggingFace models
HF_TOKEN=your_huggingface_token_here

# Training options
DATASET=bridge_orig                  # OXE dataset name passed to scripts/train.sh
DATASET_DIR=./datasets               # can point to external volume on Lambda
NUM_GPUS=1
