# ─────────────────────────────────────────────────────────────────────────────
# PhysicalAI — Development Image
#
# Extends the base image with dev tools: Jupyter, ruff, mypy, pytest.
# Must build physicalai:latest first: make docker-build
#
# Build:
#   make docker-build-dev
#
# Run Jupyter (accessible at http://localhost:8888):
#   make docker-dev
# ─────────────────────────────────────────────────────────────────────────────

FROM physicalai:latest

USER root

# Dev tools
RUN pip install \
    pytest>=8.0 \
    pytest-cov>=5.0 \
    ruff>=0.4 \
    mypy>=1.9 \
    ipykernel>=6.29 \
    jupyterlab>=4.0 \
    ipywidgets>=8.0 \
    matplotlib>=3.8

USER appuser

# Expose Jupyter port
EXPOSE 8888

# JupyterLab 4 uses ServerApp (not the deprecated NotebookApp)
CMD ["jupyter", "lab", "--ip=0.0.0.0", "--no-browser", "--ServerApp.token=''", "--ServerApp.password=''"]
