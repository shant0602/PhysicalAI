# Default arguments for OpenVLA LoRA fine-tuning.
# Source this file or pass args directly to scripts/train.sh.
# All variables map 1:1 to CLI args in vla-scripts/finetune.py.
#
# Usage: source configs/training/openvla_lora.env && bash scripts/train.sh
# Or:    make train  (Makefile reads this file automatically)

VLA_PATH="openvla/openvla-7b"
DATASET_NAME="bridge_orig"           # change to your downloaded OXE dataset name
DATA_ROOT_DIR="datasets/open-x-embodiment"
RUN_ROOT_DIR="runs"
ADAPTER_TMP_DIR="adapter-tmp"

# Training
BATCH_SIZE=16
MAX_STEPS=200000
SAVE_STEPS=5000
LEARNING_RATE=5e-4
GRAD_ACCUMULATION_STEPS=1
IMAGE_AUG=true
SHUFFLE_BUFFER_SIZE=100000
SAVE_LATEST_CHECKPOINT_ONLY=true

# LoRA
USE_LORA=true
LORA_RANK=32
LORA_DROPOUT=0.0
USE_QUANTIZATION=false

# W&B — REQUIRED: set WANDB_ENTITY to your username/team
WANDB_PROJECT="physicalai-openvla"
WANDB_ENTITY=""          # set here or export WANDB_ENTITY=myteam in shell

# Multi-GPU
NUM_GPUS=1
