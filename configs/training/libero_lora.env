# LIBERO LoRA fine-tuning config for OpenVLA.
# Task suite: libero_spatial (10 spatial-variation tasks, ~10GB).
# Source this file or use: make train-libero WANDB_ENTITY=yourname
#
# All variables map 1:1 to CLI args in vla-scripts/finetune.py.

VLA_PATH="openvla/openvla-7b"
DATASET_NAME="libero_spatial_no_noops"
DATA_ROOT_DIR="datasets/modified_libero_rlds"
RUN_ROOT_DIR="runs"
ADAPTER_TMP_DIR="adapter-tmp"

# Training — 10k steps is ~2-3 hrs on a single A100 for libero_spatial
BATCH_SIZE=16
MAX_STEPS=10000
SAVE_STEPS=500
LEARNING_RATE=5e-4
GRAD_ACCUMULATION_STEPS=1
IMAGE_AUG=true
SHUFFLE_BUFFER_SIZE=10000
SAVE_LATEST_CHECKPOINT_ONLY=true

# LoRA
USE_LORA=true
LORA_RANK=32
LORA_DROPOUT=0.0
USE_QUANTIZATION=false

# W&B — REQUIRED: set WANDB_ENTITY to your username/team
WANDB_PROJECT="physicalai-openvla"
WANDB_ENTITY=""

# Multi-GPU
NUM_GPUS=1
